{
  "schema_name": "zones",
  "description": "Generated schema template for zones.",
  "schema": {
    "file": "zones.json",
    "top_level_type": "array",
    "id_field": "zone_id",
    "id_prefixes": [
      "zone."
    ],
    "fields": {
      "zone_id": {
        "type": "string",
        "required": true
      },
      "name": {
        "type": "string",
        "required": true
      },
      "repopulate_game_hours": {
        "type": "integer",
        "required": false,
        "default": 0,
        "minimum": 0
      },
      "repopulate_each_game_hour": {
        "type": "boolean",
        "required": false,
        "legacy_alias": true,
        "notes": "Legacy compatibility flag; prefer repopulate_game_hours."
      },
      "reset_player_flags": {
        "type": "array[string]",
        "required": false,
        "default": [],
        "notes": "When the zone repopulates, these per-player interaction flags are cleared for all active characters."
      },
      "reset_container_template_ids": {
        "type": "array[string]",
        "required": false,
        "default": [],
        "notes": "When the zone repopulates, any room containers using these item template ids are reset to their configured default state and contents."
      }
    }
  }
}
