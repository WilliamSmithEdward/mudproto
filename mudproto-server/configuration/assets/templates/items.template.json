{
  "schema_name": "items",
  "description": "Generated schema template for items.",
  "schema": {
    "file": "items.json",
    "top_level_type": "array",
    "id_field": "template_id",
    "id_prefixes": [
      "item."
    ],
    "fields": {
      "template_id": {
        "type": "string",
        "required": true
      },
      "name": {
        "type": "string",
        "required": true
      },
      "description": {
        "type": "string",
        "required": false,
        "default": ""
      },
      "keywords": {
        "type": "array[string]",
        "required": false,
        "default": []
      },
      "item_type": {
        "type": "string",
        "required": false,
        "default": "consumable",
        "allowed_values": [
          "consumable",
          "key",
          "misc"
        ]
      },
      "effect_type": {
        "type": "string",
        "required": false,
        "allowed_values": [
          "restore"
        ],
        "notes": "Required for consumable restore items; omit for keys and misc items."
      },
      "effect_target": {
        "type": "string",
        "required": false,
        "allowed_values": [
          "hit_points",
          "mana",
          "vigor"
        ],
        "notes": "Required for consumable restore items; omit for keys and misc items."
      },
      "effect_amount": {
        "type": "integer",
        "required": false,
        "minimum": 1,
        "notes": "Required for consumable restore items; omit for keys and misc items."
      },
      "persistent": {
        "type": "boolean",
        "required": false,
        "default": true,
        "notes": "When false, the item is purged from character inventory/equipment on permanent disconnect or future logout-style cleanup flows."
      },
      "lock_ids": {
        "type": "array[string]",
        "required": false,
        "default": [],
        "notes": "For keys, list the lock IDs this item can lock or unlock."
      },
      "coin_value": {
        "type": "integer",
        "required": false,
        "default": 0,
        "minimum": 0
      },
      "use_lag_seconds": {
        "type": "number",
        "required": false,
        "default": 0.0,
        "minimum": 0.0
      },
      "observer_action": {
        "type": "string",
        "required": false,
        "default": ""
      },
      "observer_context": {
        "type": "string",
        "required": false,
        "default": ""
      }
    }
  }
}
