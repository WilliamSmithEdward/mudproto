{
  "schema_name": "items",
  "description": "Generated schema template for items.",
  "schema": {
    "file": "items.json",
    "top_level_type": "array",
    "id_field": "template_id",
    "id_prefixes": [
      "item."
    ],
    "fields": {
      "template_id": {
        "type": "string",
        "required": true
      },
      "name": {
        "type": "string",
        "required": true
      },
      "description": {
        "type": "string",
        "required": false,
        "default": ""
      },
      "keywords": {
        "type": "array[string]",
        "required": false,
        "default": []
      },
      "item_type": {
        "type": "string",
        "required": false,
        "default": "consumable",
        "allowed_values": [
          "consumable",
          "key",
          "misc",
          "container"
        ]
      },
      "effect_type": {
        "type": "string",
        "required": false,
        "allowed_values": [
          "restore"
        ],
        "notes": "Required for consumable restore items; omit for keys and misc items."
      },
      "effect_target": {
        "type": "string",
        "required": false,
        "allowed_values": [
          "hit_points",
          "mana",
          "vigor"
        ],
        "notes": "Required for consumable restore items; omit for keys and misc items."
      },
      "effect_amount": {
        "type": "integer",
        "required": false,
        "minimum": 1,
        "notes": "Required for consumable restore items; omit for keys and misc items."
      },
      "persistent": {
        "type": "boolean",
        "required": false,
        "default": true,
        "notes": "When false, the item is purged from character inventory/equipment on permanent disconnect or future logout-style cleanup flows."
      },
      "lock_ids": {
        "type": "array[string]",
        "required": false,
        "default": [],
        "notes": "For keys, list the lock IDs this item can lock or unlock."
      },
      "portable": {
        "type": "boolean",
        "required": false,
        "default": true,
        "notes": "For container items, when false the container can exist in the room but cannot be picked up into inventory. The alias `carryable` is also accepted."
      },
      "contents": {
        "type": "array[object]",
        "required": false,
        "default": [],
        "notes": "For containers, default item contents that are spawned inside when the container is created or reset from its template.",
        "entry_schema": {
          "template_id": {
            "type": "string",
            "required": true,
            "notes": "Must match an existing gear or item template id."
          },
          "quantity": {
            "type": "integer",
            "required": false,
            "default": 1,
            "minimum": 1
          }
        }
      },
      "consume_on_use": {
        "type": "boolean",
        "required": false,
        "default": false,
        "notes": "For keys or other special items, when true the item is removed after a successful use such as unlocking a chest."
      },
      "consume_message": {
        "type": "string",
        "required": false,
        "default": "",
        "notes": "Optional text shown when a consume_on_use item is spent."
      },
      "decay_game_hours": {
        "type": "integer",
        "required": false,
        "default": 0,
        "minimum": 0,
        "notes": "When greater than zero, the item automatically decays after this many game hours whether carried, dropped, or stored in a container."
      },
      "decay_message": {
        "type": "string",
        "required": false,
        "default": "",
        "notes": "Optional text for decay-driven expiry; currently most useful for carried items."
      },
      "can_close": {
        "type": "boolean",
        "required": false,
        "default": "true for containers",
        "notes": "For containers, controls whether `open` and `close` commands apply."
      },
      "can_lock": {
        "type": "boolean",
        "required": false,
        "default": "true when lock_id is provided",
        "notes": "For containers, controls whether `lock` and `unlock` commands apply."
      },
      "lock_id": {
        "type": "string",
        "required": false,
        "default": "",
        "notes": "For lockable containers, the single lock id that a matching key item can open."
      },
      "is_closed": {
        "type": "boolean",
        "required": false,
        "default": false
      },
      "is_locked": {
        "type": "boolean",
        "required": false,
        "default": false
      },
      "open_message": {
        "type": "string",
        "required": false,
        "default": ""
      },
      "close_message": {
        "type": "string",
        "required": false,
        "default": ""
      },
      "lock_message": {
        "type": "string",
        "required": false,
        "default": ""
      },
      "unlock_message": {
        "type": "string",
        "required": false,
        "default": ""
      },
      "closed_message": {
        "type": "string",
        "required": false,
        "default": ""
      },
      "locked_message": {
        "type": "string",
        "required": false,
        "default": ""
      },
      "needs_key_message": {
        "type": "string",
        "required": false,
        "default": ""
      },
      "must_close_to_lock_message": {
        "type": "string",
        "required": false,
        "default": ""
      },
      "already_open_message": {
        "type": "string",
        "required": false,
        "default": ""
      },
      "already_closed_message": {
        "type": "string",
        "required": false,
        "default": ""
      },
      "already_locked_message": {
        "type": "string",
        "required": false,
        "default": ""
      },
      "already_unlocked_message": {
        "type": "string",
        "required": false,
        "default": ""
      },
      "coin_value": {
        "type": "integer",
        "required": false,
        "default": 0,
        "minimum": 0
      },
      "use_lag_seconds": {
        "type": "number",
        "required": false,
        "default": 0.0,
        "minimum": 0.0
      },
      "observer_action": {
        "type": "string",
        "required": false,
        "default": ""
      },
      "observer_context": {
        "type": "string",
        "required": false,
        "default": ""
      }
    }
  }
}
