{
  "schema_name": "npcs",
  "description": "Generated schema template for npcs.",
  "schema": {
    "file": "npcs.json",
    "top_level_type": "object",
    "top_level_key": "npcs",
    "id_field": "npc_id",
    "id_prefixes": [
      "npc."
    ],
    "fields": {
      "npc_id": {
        "type": "string",
        "required": true
      },
      "name": {
        "type": "string",
        "required": true
      },
      "hit_points": {
        "type": "integer",
        "required": false,
        "default": "max_hit_points"
      },
      "max_hit_points": {
        "type": "integer",
        "required": true,
        "minimum": 1
      },
      "power_level": {
        "type": "integer",
        "required": false,
        "default": 1,
        "minimum": 0
      },
      "attacks_per_round": {
        "type": "integer",
        "required": false,
        "default": 1
      },
      "hit_roll_modifier": {
        "type": "integer",
        "required": false,
        "default": 0
      },
      "armor_class": {
        "type": "integer",
        "required": false,
        "default": 10
      },
      "off_hand_attacks_per_round": {
        "type": "integer",
        "required": false,
        "default": 0
      },
      "off_hand_hit_roll_modifier": {
        "type": "integer",
        "required": false,
        "default": 0
      },
      "coin_reward": {
        "type": "integer",
        "required": false,
        "default": 0,
        "minimum": 0
      },
      "experience_reward": {
        "type": "integer",
        "required": false,
        "default": 0,
        "minimum": 0
      },
      "is_aggro": {
        "type": "boolean",
        "required": false,
        "default": false
      },
      "is_ally": {
        "type": "boolean",
        "required": false,
        "default": false
      },
      "is_peaceful": {
        "type": "boolean",
        "required": false,
        "default": false
      },
      "respawn": {
        "type": "boolean",
        "required": false,
        "default": true
      },
      "is_merchant": {
        "type": "boolean",
        "required": false,
        "default": false
      },
      "merchant_inventory": {
        "type": "array[object]",
        "required": false,
        "default": [],
        "entry_schema": {
          "template_id": {
            "type": "string",
            "required": true
          },
          "infinite": {
            "type": "boolean",
            "required": false,
            "default": false
          },
          "quantity": {
            "type": "integer",
            "required": false,
            "default": 1,
            "minimum": 0
          }
        }
      },
      "merchant_inventory_template_ids": {
        "type": "array[string]",
        "required": false,
        "default": [],
        "legacy_alias": true
      },
      "merchant_buy_markup": {
        "type": "number",
        "required": false,
        "default": 1.0,
        "exclusive_minimum": 0.0
      },
      "merchant_sell_ratio": {
        "type": "number",
        "required": false,
        "default": 0.5,
        "minimum": 0.0,
        "maximum": 1.0
      },
      "pronoun_possessive": {
        "type": "string",
        "required": false,
        "default": "its"
      },
      "main_hand_weapon": {
        "type": "object",
        "required": false,
        "default": {},
        "schema": {
          "template_id": {
            "type": "string",
            "required": false,
            "default": "",
            "notes": "Must match an existing gear template_id when provided."
          },
          "spawn_chance": {
            "type": "number",
            "required": false,
            "default": 100,
            "minimum": 0,
            "maximum": 100
          },
          "drop_on_death": {
            "type": "number",
            "required": false,
            "default": 0,
            "minimum": 0,
            "maximum": 100,
            "notes": "Percent chance for this equipped weapon to appear on the corpse when the NPC dies."
          }
        }
      },
      "off_hand_weapon": {
        "type": "object",
        "required": false,
        "default": {},
        "schema": {
          "template_id": {
            "type": "string",
            "required": false,
            "default": "",
            "notes": "Must match an existing gear template_id when provided."
          },
          "spawn_chance": {
            "type": "number",
            "required": false,
            "default": 100,
            "minimum": 0,
            "maximum": 100
          },
          "drop_on_death": {
            "type": "number",
            "required": false,
            "default": 0,
            "minimum": 0,
            "maximum": 100,
            "notes": "Percent chance for this equipped weapon to appear on the corpse when the NPC dies."
          }
        }
      },
      "vigor": {
        "type": "integer",
        "required": false,
        "default": "max_vigor",
        "minimum": 0
      },
      "max_vigor": {
        "type": "integer",
        "required": false,
        "default": 0,
        "minimum": 0
      },
      "mana": {
        "type": "integer",
        "required": false,
        "default": "max_mana",
        "minimum": 0
      },
      "max_mana": {
        "type": "integer",
        "required": false,
        "default": 0,
        "minimum": 0
      },
      "skill_use_chance": {
        "type": "number",
        "required": false,
        "default": 0.35,
        "minimum": 0.0,
        "maximum": 1.0
      },
      "skill_ids": {
        "type": "array[string]",
        "required": false,
        "default": []
      },
      "spell_use_chance": {
        "type": "number",
        "required": false,
        "default": 0.25,
        "minimum": 0.0,
        "maximum": 1.0
      },
      "spell_ids": {
        "type": "array[string]",
        "required": false,
        "default": []
      },
      "room_communications": {
        "type": "array[object]",
        "required": false,
        "default": [],
        "entry_schema": {
          "trigger": {
            "type": "string",
            "required": false,
            "default": "player_enter",
            "allowed_values": ["player_enter"]
          },
          "audience": {
            "type": "string",
            "required": false,
            "default": "both",
            "allowed_values": ["private", "room", "both"],
            "notes": "`private` shows only to the entering player, `room` broadcasts only to the room, and `both` does both."
          },
          "required_player_flags": {
            "type": "array[string]",
            "required": false,
            "default": []
          },
          "excluded_player_flags": {
            "type": "array[string]",
            "required": false,
            "default": []
          },
          "set_player_flags": {
            "type": "array[string]",
            "required": false,
            "default": []
          },
          "clear_player_flags": {
            "type": "array[string]",
            "required": false,
            "default": []
          },
          "required_world_flags": {
            "type": "array[string]",
            "required": false,
            "default": []
          },
          "excluded_world_flags": {
            "type": "array[string]",
            "required": false,
            "default": []
          },
          "set_world_flags": {
            "type": "array[string]",
            "required": false,
            "default": []
          },
          "clear_world_flags": {
            "type": "array[string]",
            "required": false,
            "default": []
          },
          "message": {
            "type": "string",
            "required": true,
            "notes": "Shown when the configured trigger fires, such as a player entering the NPC's room."
          }
        }
      },
      "keyword_actions": {
        "type": "array[object]",
        "required": false,
        "default": [],
        "notes": "NPC-side command triggers. Uses the same structure as room keyword_actions and supports `noop` and `grant_item` actions as well as room exit reveal/hide actions.",
        "entry_schema": {
          "keywords": {
            "type": "array[string]",
            "required": true
          },
          "message": {
            "type": "string",
            "required": false,
            "default": ""
          },
          "already_message": {
            "type": "string",
            "required": false,
            "default": ""
          },
          "refresh_view": {
            "type": "string",
            "required": false,
            "default": "none",
            "allowed_values": ["none", "exits", "room"]
          },
          "required_player_flags": {
            "type": "array[string]",
            "required": false,
            "default": []
          },
          "excluded_player_flags": {
            "type": "array[string]",
            "required": false,
            "default": []
          },
          "set_player_flags": {
            "type": "array[string]",
            "required": false,
            "default": []
          },
          "clear_player_flags": {
            "type": "array[string]",
            "required": false,
            "default": []
          },
          "required_world_flags": {
            "type": "array[string]",
            "required": false,
            "default": []
          },
          "excluded_world_flags": {
            "type": "array[string]",
            "required": false,
            "default": []
          },
          "set_world_flags": {
            "type": "array[string]",
            "required": false,
            "default": []
          },
          "clear_world_flags": {
            "type": "array[string]",
            "required": false,
            "default": []
          },
          "actions": {
            "type": "array[object]",
            "required": true,
            "notes": "Supports `noop`, `grant_item`, `teleport_player`, and the standard room exit action types."
          }
        }
      },
      "inventory_items": {
        "type": "array[object]",
        "required": false,
        "default": [],
        "entry_schema": {
          "template_id": {
            "type": "string",
            "required": true,
            "notes": "Must match an existing gear or item template id. Spawned items transfer to the corpse on NPC death."
          },
          "quantity": {
            "type": "integer",
            "required": false,
            "default": 1,
            "minimum": 1
          },
          "spawn_chance": {
            "type": "number",
            "required": false,
            "default": 100,
            "minimum": 0,
            "maximum": 100,
            "notes": "Percent chance for each quantity instance to appear on the NPC when it spawns."
          }
        }
      },
      "wander_chance": {
        "type": "number",
        "required": false,
        "default": 0.0,
        "minimum": 0.0,
        "maximum": 1.0,
        "notes": "Probability each tick that this NPC attempts to wander. 0.0 disables wandering. Typical range is 0.05-0.15."
      },
      "wander_room_ids": {
        "type": "array[string]",
        "required": false,
        "default": [],
        "notes": "Room IDs this NPC is allowed to wander between. The NPC will only move to rooms that are both in this list AND directly reachable via its current room's exits. All listed rooms should form a connected subgraph."
      }
    }
  }
}
