{
  "schema_name": "npcs",
  "description": "Generated schema template for npcs.",
  "schema": {
    "file": "npcs.json",
    "top_level_type": "object",
    "top_level_key": "npcs",
    "id_field": "npc_id",
    "id_prefixes": [
      "npc."
    ],
    "fields": {
      "npc_id": {
        "type": "string",
        "required": true
      },
      "name": {
        "type": "string",
        "required": true
      },
      "is_named": {
        "type": "boolean",
        "required": false,
        "default": false,
        "notes": "Explicit naming control. Set true for uniquely named or story-significant NPCs that should render without an indefinite article in combat and room text; leave false for ordinary generic mobs. Named NPC corpses render as full possessive labels such as 'Brother Cleft's corpse'."
      },
      "hit_points": {
        "type": "integer",
        "required": false,
        "default": "max_hit_points"
      },
      "max_hit_points": {
        "type": "integer",
        "required": true,
        "minimum": 1
      },
      "power_level": {
        "type": "integer",
        "required": false,
        "default": 1,
        "minimum": 0
      },
      "attacks_per_round": {
        "type": "integer",
        "required": false,
        "default": 1
      },
      "hit_roll_modifier": {
        "type": "integer",
        "required": false,
        "default": 0
      },
      "armor_class": {
        "type": "integer",
        "required": false,
        "default": 10
      },
      "off_hand_attacks_per_round": {
        "type": "integer",
        "required": false,
        "default": 0
      },
      "off_hand_hit_roll_modifier": {
        "type": "integer",
        "required": false,
        "default": 0
      },
      "coin_reward": {
        "type": "integer",
        "required": false,
        "default": 0,
        "minimum": 0
      },
      "experience_reward": {
        "type": "integer",
        "required": false,
        "default": 0,
        "minimum": 0
      },
      "is_aggro": {
        "type": "boolean",
        "required": false,
        "default": false
      },
      "is_ally": {
        "type": "boolean",
        "required": false,
        "default": false
      },
      "is_peaceful": {
        "type": "boolean",
        "required": false,
        "default": false
      },
      "aggro_player_flags": {
        "type": "array[string]",
        "required": false,
        "default": [],
        "notes": "When a player with any of these player flags enters the NPC's room, the NPC auto-engages them in combat."
      },
      "set_player_flags_on_hostile_action": {
        "type": "array[string]",
        "required": false,
        "default": [],
        "notes": "Player flags set on the attacking player when they initiate combat against this NPC."
      },
      "set_player_flags_on_death": {
        "type": "array[string]",
        "required": false,
        "default": [],
        "notes": "Player flags set on the killing player when this NPC dies."
      },
      "set_world_flags_on_death": {
        "type": "array[string]",
        "required": false,
        "default": [],
        "notes": "World flags set when this NPC dies. Critical for flag_spawns chains where killing one NPC triggers spawning of the next."
      },
      "corpse_label_style": {
        "type": "string",
        "required": false,
        "default": "generic",
        "allowed_values": ["generic", "possessive"],
        "notes": "Controls corpse naming. generic produces 'the corpse of a Goblin', possessive produces 'Brother Cleft's corpse'. Typically use possessive for is_named NPCs."
      },
      "respawn": {
        "type": "boolean",
        "required": false,
        "default": true
      },
      "is_merchant": {
        "type": "boolean",
        "required": false,
        "default": false
      },
      "merchant_inventory": {
        "type": "array[object]",
        "required": false,
        "default": [],
        "entry_schema": {
          "template_id": {
            "type": "string",
            "required": true
          },
          "infinite": {
            "type": "boolean",
            "required": false,
            "default": false
          },
          "quantity": {
            "type": "integer",
            "required": false,
            "default": 1,
            "minimum": 0
          }
        }
      },
      "merchant_inventory_template_ids": {
        "type": "array[string]",
        "required": false,
        "default": [],
        "legacy_alias": true
      },
      "merchant_buy_markup": {
        "type": "number",
        "required": false,
        "default": 1.0,
        "exclusive_minimum": 0.0
      },
      "merchant_sell_ratio": {
        "type": "number",
        "required": false,
        "default": 0.5,
        "minimum": 0.0,
        "maximum": 1.0
      },
      "merchant_restock_game_hours": {
        "type": "integer",
        "required": false,
        "default": 0,
        "minimum": 0,
        "notes": "If greater than 0, limited merchant stock replenishes to its configured quantity after this many game hours."
      },
      "pronoun_possessive": {
        "type": "string",
        "required": false,
        "default": "its"
      },
      "main_hand_weapon": {
        "type": "object",
        "required": false,
        "default": {},
        "schema": {
          "template_id": {
            "type": "string",
            "required": false,
            "default": "",
            "notes": "Must match an existing gear template_id when provided."
          },
          "spawn_chance": {
            "type": "number",
            "required": false,
            "default": 100,
            "minimum": 0,
            "maximum": 100
          },
          "drop_on_death": {
            "type": "number",
            "required": false,
            "default": 0,
            "minimum": 0,
            "maximum": 100,
            "notes": "Percent chance for this equipped weapon to appear on the corpse when the NPC dies."
          }
        }
      },
      "off_hand_weapon": {
        "type": "object",
        "required": false,
        "default": {},
        "schema": {
          "template_id": {
            "type": "string",
            "required": false,
            "default": "",
            "notes": "Must match an existing gear template_id when provided."
          },
          "spawn_chance": {
            "type": "number",
            "required": false,
            "default": 100,
            "minimum": 0,
            "maximum": 100
          },
          "drop_on_death": {
            "type": "number",
            "required": false,
            "default": 0,
            "minimum": 0,
            "maximum": 100,
            "notes": "Percent chance for this equipped weapon to appear on the corpse when the NPC dies."
          }
        }
      },
      "vigor": {
        "type": "integer",
        "required": false,
        "default": "max_vigor",
        "minimum": 0
      },
      "max_vigor": {
        "type": "integer",
        "required": false,
        "default": 0,
        "minimum": 0
      },
      "mana": {
        "type": "integer",
        "required": false,
        "default": "max_mana",
        "minimum": 0
      },
      "max_mana": {
        "type": "integer",
        "required": false,
        "default": 0,
        "minimum": 0
      },
      "skill_use_chance": {
        "type": "number",
        "required": false,
        "default": 0.35,
        "minimum": 0.0,
        "maximum": 1.0
      },
      "skill_ids": {
        "type": "array[string]",
        "required": false,
        "default": []
      },
      "spell_use_chance": {
        "type": "number",
        "required": false,
        "default": 0.25,
        "minimum": 0.0,
        "maximum": 1.0
      },
      "spell_ids": {
        "type": "array[string]",
        "required": false,
        "default": []
      },
      "room_communications": {
        "type": "array[object]",
        "required": false,
        "default": [],
        "entry_schema": {
          "trigger": {
            "type": "string",
            "required": false,
            "default": "player_enter",
            "allowed_values": ["player_enter"]
          },
          "audience": {
            "type": "string",
            "required": false,
            "default": "both",
            "allowed_values": ["private", "room", "both"],
            "notes": "`private` shows only to the entering player, `room` broadcasts only to the room, and `both` does both."
          },
          "required_player_flags": {
            "type": "array[string]",
            "required": false,
            "default": []
          },
          "excluded_player_flags": {
            "type": "array[string]",
            "required": false,
            "default": []
          },
          "set_player_flags": {
            "type": "array[string]",
            "required": false,
            "default": []
          },
          "clear_player_flags": {
            "type": "array[string]",
            "required": false,
            "default": []
          },
          "required_world_flags": {
            "type": "array[string]",
            "required": false,
            "default": []
          },
          "excluded_world_flags": {
            "type": "array[string]",
            "required": false,
            "default": []
          },
          "set_world_flags": {
            "type": "array[string]",
            "required": false,
            "default": []
          },
          "clear_world_flags": {
            "type": "array[string]",
            "required": false,
            "default": []
          },
          "message": {
            "type": "string",
            "required": true,
            "notes": "Shown when the configured trigger fires, such as a player entering the NPC's room."
          },
          "required_item_template_ids": {
            "type": "array[string]",
            "required": false,
            "default": [],
            "notes": "Player must have all of these items in inventory or equipment for this communication to fire."
          },
          "excluded_item_template_ids": {
            "type": "array[string]",
            "required": false,
            "default": [],
            "notes": "Communication is suppressed if the player has any of these items."
          }
        }
      },
      "keyword_actions": {
        "type": "array[object]",
        "required": false,
        "default": [],
        "notes": "NPC-side command triggers. Uses the same structure as room keyword_actions and supports noop, grant_item, remove_item, award_experience, teleport_player, and room exit reveal/hide actions.",
        "entry_schema": {
          "keywords": {
            "type": "array[string]",
            "required": true
          },
          "message": {
            "type": "string",
            "required": false,
            "default": ""
          },
          "already_message": {
            "type": "string",
            "required": false,
            "default": ""
          },
          "refresh_view": {
            "type": "string",
            "required": false,
            "default": "none",
            "allowed_values": ["none", "exits", "room"]
          },
          "required_player_flags": {
            "type": "array[string]",
            "required": false,
            "default": []
          },
          "excluded_player_flags": {
            "type": "array[string]",
            "required": false,
            "default": []
          },
          "set_player_flags": {
            "type": "array[string]",
            "required": false,
            "default": []
          },
          "clear_player_flags": {
            "type": "array[string]",
            "required": false,
            "default": []
          },
          "required_world_flags": {
            "type": "array[string]",
            "required": false,
            "default": []
          },
          "excluded_world_flags": {
            "type": "array[string]",
            "required": false,
            "default": []
          },
          "set_world_flags": {
            "type": "array[string]",
            "required": false,
            "default": []
          },
          "clear_world_flags": {
            "type": "array[string]",
            "required": false,
            "default": []
          },
          "actions": {
            "type": "array[object]",
            "required": true,
            "notes": "Supports noop, grant_item, remove_item, award_experience, teleport_player, and the standard room exit reveal/hide action types."
          },
          "required_item_template_ids": {
            "type": "array[string]",
            "required": false,
            "default": [],
            "notes": "Player must have all of these items in inventory or equipment for this action to be available."
          },
          "excluded_item_template_ids": {
            "type": "array[string]",
            "required": false,
            "default": [],
            "notes": "Action is unavailable if the player has any of these items."
          }
        }
      },
      "inventory_items": {
        "type": "array[object]",
        "required": false,
        "default": [],
        "entry_schema": {
          "template_id": {
            "type": "string",
            "required": true,
            "notes": "Must match an existing gear or item template id. Spawned items transfer to the corpse on NPC death."
          },
          "quantity": {
            "type": "integer",
            "required": false,
            "default": 1,
            "minimum": 1
          },
          "spawn_chance": {
            "type": "number",
            "required": false,
            "default": 100,
            "minimum": 0,
            "maximum": 100,
            "notes": "Percent chance for each quantity instance to appear on the NPC when it spawns."
          }
        }
      },
      "wander_chance": {
        "type": "number",
        "required": false,
        "default": 0.0,
        "minimum": 0.0,
        "maximum": 1.0,
        "notes": "Probability each tick that this NPC attempts to wander. 0.0 disables wandering. Typical range is 0.05-0.15."
      },
      "wander_room_ids": {
        "type": "array[string]",
        "required": false,
        "default": [],
        "notes": "Room IDs this NPC is allowed to wander between. The NPC will only move to rooms that are both in this list AND directly reachable via its current room's exits. All listed rooms should form a connected subgraph."
      }
    }
  }
}
